{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": "data/**" }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/membre.html", "dest": "/public/membre.html" },
    { "src": "/visiteur.html", "dest": "/public/visiteur.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
